# Copy this file to .env in THIS directory (infra/docker/) — NOT skypvp-web/.env
# Used by infra/docker/compose.yaml when you run: docker compose up
#
# SPVP_REDIS_HOST=host.docker.internal
# SPVP_POSTGRES_HOST=host.docker.internal
# SPVP_POSTGRES_PASSWORD=change-me
# SPVP_IN_GAME_PLUGIN_SECRET=super-secret-change-me
#
# Azure Content Moderator (chat.moderation in SkyPvPCore)
SPVP_CHAT_MODERATION_ENABLED=false
SPVP_CHAT_MODERATION_ENDPOINT=
SPVP_CHAT_MODERATION_API_KEY=
#
# Chat auto-translate (Social menu → Auto-translate). Uses Azure Cognitive Services.
SPVP_CHAT_TRANSLATION_ENABLED=false
SPVP_CHAT_TRANSLATION_ENDPOINT=https://api.cognitive.microsofttranslator.com
SPVP_CHAT_TRANSLATION_API_KEY=
SPVP_CHAT_TRANSLATION_REGION=
SPVP_CHAT_TRANSLATION_DEBUG=false
