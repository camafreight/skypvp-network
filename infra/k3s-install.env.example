# Copy to infra/k3s-install.env (gitignored) and source before running install scripts.
# NEVER commit the real token. Rotate on the server if it was ever pushed to git.
#
# Server bootstrap (install_k3s.sh):
#   export K3S_TOKEN="K10....::server:...."
#   export INSTALL_K3S_EXEC='server --cluster-init'
#   bash infra/install_k3s.sh
#
# Agent join (install_agent.sh):
#   export K3S_URL="https://YOUR_CONTROL_PLANE_IP:6443"
#   export K3S_TOKEN="K10....::server:...."
#   bash infra/install_agent.sh

K3S_URL="https://192.168.0.25:6443"
K3S_TOKEN="CHANGE_ME"
